# Copy to .env and fill in real values. Never commit .env.
#
# This single file is the source of truth for app config on BOTH run paths:
#   - Host run (uvicorn from backend/): the app reads it directly (pydantic-settings).
#   - Docker (`docker compose up`): the backend service loads it via `env_file`, and
#     docker-compose.yml overrides DATABASE_URL to reach Postgres at the `db` service.

# PostgreSQL connection (async driver form — must use postgresql+asyncpg://).
# Used as-is for the host run; under Docker it is overridden to the `db` service host.
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/banking_crm

# Anthropic API key (required). Obtain from the Anthropic console.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model configuration. Defaults are claude-opus-4-8 for both; override here to
# swap either the agent model or the message-generation model with no code change.
# Do NOT add temperature/top_p/top_k/budget_tokens — they 400 on Opus 4.8.
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MESSAGE_MODEL=claude-opus-4-8

# Logging verbosity (optional; defaults to INFO).
LOG_LEVEL=INFO

# CORS origin for the locally-run Next.js frontend (optional; defaults to this).
FRONTEND_ORIGIN=http://localhost:3000
